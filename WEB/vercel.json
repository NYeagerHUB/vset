{
  "version": 2,
  "routes": [
    {
      "src": "/style.css",
      "headers": { "content-type": "text/css; charset=utf-8" },
      "dest": "/WEB/style.css"
    },
    {
      "src": "/exam.js",
      "headers": { "content-type": "application/javascript; charset=utf-8" },
      "dest": "/WEB/exam.js"
    },
    {
      "src": "/pdf-import.js",
      "headers": { "content-type": "application/javascript; charset=utf-8" },
      "dest": "/WEB/pdf-import.js"
    },
    {
      "src": "/gemini-import.js",
      "headers": { "content-type": "application/javascript; charset=utf-8" },
      "dest": "/WEB/gemini-import.js"
    },
    { "src": "/", "dest": "/WEB/index.html" },
    { "src": "/(.*)", "dest": "/WEB/$1" }
  ]
}
